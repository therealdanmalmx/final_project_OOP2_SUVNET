@inject NavigationManager Nav
@using API.DTO.Review
@using AngleSharp.Text
@using Client.DTO

<BbCard class="w-[360px] overflow-hidden rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 bg-white group">

    <div class="relative">
        <img src="@restaurant.Image"
             alt="@restaurant.Name"
             class="w-full h-56 object-cover transition-transform duration-500 group-hover:scale-105" />

        <div class="absolute inset-0 bg-linear-to-t from-black/50 to-transparent" />

        <span class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm text-xs font-semibold tracking-widest uppercase text-gray-700 px-3 py-1 rounded-full shadow-sm">
            @restaurant.Category
        </span>

        <div class="absolute bottom-3 left-4 flex items-center gap-1.5">
            <svg class="w-4 h-4 text-amber-400 fill-amber-400" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <span class="text-white text-sm font-semibold drop-shadow">@(ReviewAverage == 0 ? "No reviews" : ReviewAverage)</span>
        </div>
    </div>

    <BbCardHeader class="pb-2 pt-4 px-5">
        <BbCardTitle class="text-xl font-bold tracking-tight text-gray-900 leading-snug">
            @restaurant.Name
        </BbCardTitle>
        <BbCardDescription class="text-sm text-gray-500 mt-1 line-clamp-2 leading-relaxed">
            @restaurant.Description
        </BbCardDescription>
    </BbCardHeader>

    <BbCardFooter class="px-5 pb-5 pt-1">
        <BbButton
            @onclick="@(() => Nav.NavigateTo($"/restaurant/{restaurant.Id}"))"
            class="w-full bg-gray-900 hover:bg-gray-700 text-white text-sm font-semibold tracking-wide py-2.5 rounded-xl transition-colors duration-200">
            Se meny →
        </BbButton>
    </BbCardFooter>

</BbCard>

@code {
    [Parameter]
    public GetRestaurantsDTO restaurant { get; set; }
    public decimal ReviewAverage {get; set; }
    public List<AddNewReviewDTO> reviews {get; set; }


    protected override async Task OnParametersSetAsync()
    {

        reviews = await Http.GetFromJsonAsync<List<AddNewReviewDTO>>($"api/review/{restaurant.Id}")
            ?? new List<AddNewReviewDTO>();

        ReviewAverage = reviews.Any() ? reviews.Average(r => r.Score) : 0m;

    }
}