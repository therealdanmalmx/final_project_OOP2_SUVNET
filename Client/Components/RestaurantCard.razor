@inject NavigationManager Nav
@using AngleSharp.Text
@using Client.DTO

<BbCard class="w-[350px] overflow-hidden">
    <img src=@restaurant.Image alt=@restaurant.Name class="w-full h-64 object-cover" />
    <BbCardHeader>
        <BbCardTitle>@restaurant.Name</BbCardTitle>
        <BbCardDescription>@restaurant.Description</BbCardDescription>
    </BbCardHeader>
    <BbCardFooter class="flex justify-between">
        <BbButton onclick="@(() => Nav.NavigateTo($"/restaurant/{restaurant.Id}"))">Se meny</BbButton>
    </BbCardFooter>
</BbCard>

@code {
    [Parameter]
    public GetRestaurantsDTO restaurant { get; set; }
}