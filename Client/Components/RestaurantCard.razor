@using Client.DTO
@inject HttpClient Http

<BbCard class="w-[350px] overflow-hidden">
    <img src="/images/@(restaurant.Id).jpg" alt="Mountain retreat" class="aspect-video w-full object-cover" />
    <BbCardHeader>
        <BbCardTitle>@restaurant.Name</BbCardTitle>
        <BbCardDescription>@restaurant.Description</BbCardDescription>
    </BbCardHeader>
    <BbCardFooter class="flex justify-between">
        <NavLink href="/restaurant/@restaurant.Id">
            <BbButton>Se meny</BbButton>
        </NavLink>
    </BbCardFooter>
</BbCard>

@code {

    [Parameter]
    public GetRestaurantsDTO restaurant { get; set; }
}