@using Blazored.LocalStorage
@using Client.Models
@inject ILocalStorageService LocalStorage
@implements IDisposable

<nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 h-16
            bg-neutral-900 border-b border-neutral-800 shadow-lg w-full">

    <a href="/" class="text-white font-bold text-xl tracking-tight" style="text-decoration: none;">
        FoodGetAboutIt
    </a>

    <div class="flex gap-4">
        <AuthorizeView>
            <NotAuthorized>
                <BbButton Href="/register" Class="text-white rounded-full">Register</BbButton>
                <BbButton Href="/login" Class="text-white rounded-full">Login</BbButton>

            </NotAuthorized>
            <Authorized>
                <a href="@(cartCount > 0 ? "/cart" : null)" class="p-2 text-neutral-300 hover:text-orange-400 transition-colors duration-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none"
                        viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2 9m12-9l2 9M9 21a1 1 0 100-2 1 1 0 000 2zm6 0a1 1 0 100-2 1 1 0 000 2z" />
                    </svg>

                    @if (cartCount > 0)
                    {
                        <span class="absolute -top-1 -right-1 flex items-center justify-center
                            min-w-5 h-5 px-1 rounded-full
                            bg-orange-500 text-white text-[0.65rem] font-bold leading-none">
                            @(cartCount.ToString())
                        </span>
                    }
                </a>
                <BbButton Href="/logout" Class="text-white rounded-full">Logout</BbButton>
            </Authorized>
        </AuthorizeView>

    </div>
</nav>

<div class="h-24"></div>

@code {
    private int cartCount;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            LocalStorage.Changed += OnLocalStorageChanged;
            await UpdateCartCount();
        }
    }

    private async void OnLocalStorageChanged(object? sender, ChangedEventArgs e)
    {
        if (e.Key == "cart")
        {
            await UpdateCartCount();
            StateHasChanged();
        }
    }

    private async Task UpdateCartCount()
    {
        var cart = await LocalStorage.GetItemAsync<List<OrderState>>("cart");
        cartCount = cart?.Sum(item => item.Quantity) ?? 0;
        StateHasChanged();

        Console.WriteLine(cartCount);
    }

@* Necessary? *@
    public void Dispose()
    {
        LocalStorage.Changed -= OnLocalStorageChanged;
    }
}