@using Blazored.LocalStorage
@using Client.Models
@using Client.State
@inject CartStateService CartState

@implements IDisposable

<nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 h-16
            bg-neutral-900 border-b border-neutral-800 shadow-lg w-full">

    <a href="/" class="text-white font-bold text-xl tracking-tight" style="text-decoration: none;">
        FoodGetAboutIt
    </a>

    <div class="flex gap-4">
        <AuthorizeView>
            <NotAuthorized>
                <BbButton Href="/register" Class="text-white rounded-full" style="text-decoration: none">Register</BbButton>
                <BbButton Href="/login" Class="text-white rounded-full" style="text-decoration: none">Login</BbButton>

            </NotAuthorized>
            <Authorized>
            <a href="@(cartCount > 0 ? "/cart" : null)" class="relative p-2 text-neutral-300 hover:text-orange-400 transition-colors duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none"
                    viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 8.5h12.974c.576 0 1.059.435 1.119 1.007z" />
                    @if (cartCount > 0)
                    {
                    <svg:text x="12" y="21"
                        text-anchor="middle"
                        dominant-baseline="auto"
                        font-size="10"
                        font-family="sans-serif"
                        font-weight="bold"
                        fill="#ffffff"
                        stroke="none"
                        style="fill: #ffffff !important;">
                        @cartCount
                    </svg:text>
                    }
                </svg>
            </a>
                <BbButton Href="/logout" Class="text-white rounded-full" style="text-decoration: none">Logout</BbButton>
            </Authorized>
        </AuthorizeView>

    </div>
</nav>

<div class="h-24"></div>

@code {
    private int cartCount;

    protected override void OnInitialized()
    {
        CartState.OnCartChanged += OnCartChanged;
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            LocalStorage.Changed += OnLocalStorageChanged;
            await UpdateCartCount();
        }
    }

    private async void OnLocalStorageChanged(object? sender, ChangedEventArgs e)
    {
        if (e.Key == "cart")
        {
            await UpdateCartCount();
            StateHasChanged();
        }
    }
    private async void OnCartChanged()
    {
        await UpdateCartCount();
        await InvokeAsync(StateHasChanged);
    }

    private async Task UpdateCartCount()
    {
        var cart = await LocalStorage.GetItemAsync<List<OrderState>>("cart");
        cartCount = cart?.Sum(item => item.Quantity) ?? 0;
        StateHasChanged();
    }

    public void Dispose()
    {
        LocalStorage.Changed -= OnLocalStorageChanged;
        CartState.OnCartChanged -= OnCartChanged;

    }
}