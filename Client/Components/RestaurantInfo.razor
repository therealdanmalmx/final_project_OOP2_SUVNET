@using API.DTO.Review
@using Client.DTO
@using Client.Pages
@inject HttpClient Http


<div class="relative w-full overflow-hidden rounded-2xl">

        <div class="h-96 w-full overflow-hidden">
            <img src="@restaurant.Image"
            alt="@restaurant.Name"
            class="w-full h-96 object-cover object-center" />
        </div>

        @if (isopen)
        {
            <span class="absolute top-4 right-4 flex items-center gap-1.5 bg-emerald-500/90 backdrop-blur-sm text-white text-xs font-semibold px-3 py-1.5 rounded-full">
                Öppet @restaurant.Opens.ToString("HH:mm") – @restaurant.Closes.ToString("HH:mm")
            </span>
        }
        else
        {
            <span class="absolute top-4 right-4 flex items-center gap-1.5 bg-red-600 backdrop-blur-sm text-white text-xs font-semibold px-3 py-1.5 rounded-full">
                Stängt
            </span>
        }

        <div class="absolute bottom-0 left-0 right-0 px-7 p-6">
            <h1 class="text-4xl font-black tracking-tight text-white leading-none drop-shadow-sm">
                @restaurant.Name
            </h1>
            <p class="text-white text-sm mt-1.5 max-w-lg leading-relaxed">
                @restaurant.Description
            </p>
        </div>
    </div>

    <div class="bg-white border-t border-gray-100 pr-7 py-4 flex flex-wrap gap-4 items-center">

        <button class="flex items-center gap-1.5 text-sm group">
            <svg class="w-4 h-4 text-amber-400 fill-amber-400" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <span class="font-bold text-gray-900">@(ReviewAverage) / 5</span>
        </button>

        <div class="w-px h-4 bg-gray-200 hidden sm:block"></div>

        <div class="flex items-center gap-1.5 text-sm text-gray-600">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/>
            </svg>
            <span>@restaurant.DeliveyCharge kr frakt</span>
        </div>

        <div class="w-px h-4 bg-gray-200 hidden sm:block"></div>

        <div class="flex items-center gap-1.5 text-sm text-gray-600">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/>
            </svg>
            <span>Min. @restaurant.MinimumOrderValue kr</span>
        </div>

        <div class="w-px h-4 bg-gray-200 hidden sm:block"></div>

        <div class="flex items-center gap-1.5 text-sm text-gray-600">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 14.25l6-6m4.5-3.493V21.75l-3.75-1.5-3.75 1.5-3.75-1.5-3.75 1.5V4.757c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0c1.1.128 1.907 1.077 1.907 2.185z"/>
            </svg>
            <span>@restaurant.ServiceFee% serviceavgift <span class="text-gray-400">(min 6 kr)</span></span>
        </div>
    </div>

@code {
    [Parameter]
    public GetRestaurantsDTO restaurant { get; set; }

    [Parameter]
    public bool isopen {get; set; }
    public List<AddNewReviewDTO> reviews {get; set; }
    public decimal ReviewAverage {get; set; }

    protected override async Task OnParametersSetAsync()
    {

        reviews = await Http.GetFromJsonAsync<List<AddNewReviewDTO>>($"api/review/{restaurant.Id}")
            ?? new List<AddNewReviewDTO>();

        ReviewAverage = reviews.Any() ? reviews.Average(r => r.Score) : 0m;

    }
}
