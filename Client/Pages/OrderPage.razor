@page "/cart"
@inject NavigationManager Nav
@inject ILocalStorageService LocalStorage


@using API.Models
@using Blazored.LocalStorage
@using Client.DTO
@using Client.Models
@using Client.Services
@using System.ComponentModel.DataAnnotations

<div class="min-h-screen flex items-center justify-center p-6">
    <div class="w-full max-w-md">

        <h1 class="text-3xl font-black tracking-tight text-[#1a1a1a] mb-6 uppercase">
            Orderbekräftelse
        </h1>
            <div class="mb-6 space-y-2 text-[#1a1a1a]">
                @foreach(var item in cart)
                {
                    <div class="flex justify-between items-center">
                        <span class="font-bold text-base">@item?.MenuItem?.Name &nbsp; x(@item?.Quantity)</span>
                        <span class="text-base">@(item?.Quantity * item?.MenuItem?.Price):-</span>
                    </div>

                }
                <div class="flex justify-between items-center text-sm mt-3">
                    <span>Leveransavgift</span>
                    <span>@restaurantDeliveryCharge:-</span>
                </div>
                <div class="flex justify-between items-center text-sm">
                    <span>Serviceavgift (@restaurantServiceFee% )</span>
                    <span>@(itemTotal * (restaurantServiceFee/100))kr</span>
                </div>

                <div class="flex justify-between items-center font-bold text-base pt-2">
                    <span>Summa</span>
                    <span>@(itemTotal * (1 + restaurantServiceFee/100) + restaurantDeliveryCharge):-</span>
                </div>
            </div>

            <div class="space-y-0 border border-[#c8c5bb]">
                <EditForm Model="@createOrder" OnValidSubmit="ConfirmOrder">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <input
                        class="w-full px-4 py-4 bg-[#f5f3e8] text-[#1a1a1a] placeholder-[#1a1a1a] border-b border-[#c8c5bb] outline-none text-base focus:bg-[#edebd8]"
                        placeholder="Namn"
                        @bind="createOrder.Name" />

                    <input
                        class="w-full px-4 py-4 bg-[#f5f3e8] text-[#1a1a1a] placeholder-[#1a1a1a] border-b border-[#c8c5bb] outline-none text-base focus:bg-[#edebd8]"
                        placeholder="Adress"
                        @bind="createOrder.Address" />

                    <input
                        class="w-full px-4 py-4 bg-[#f5f3e8] text-[#1a1a1a] placeholder-[#1a1a1a] border-b border-[#c8c5bb] outline-none text-base focus:bg-[#edebd8]"
                        placeholder="Telefon"
                        @bind="createOrder.Phone" />

                    <input
                        class="w-full px-4 py-4 bg-[#f5f3e8] text-[#1a1a1a] placeholder-[#1a1a1a] border-b border-[#c8c5bb] outline-none text-base focus:bg-[#edebd8]"
                        placeholder="Email"
                        type="email"
                        @bind="createOrder.Email" />

                    <textarea
                        class="w-full px-4 py-4 bg-[#f5f3e8] text-[#1a1a1a] placeholder-[#1a1a1a] outline-none text-base resize-none h-32 focus:bg-[#edebd8]"
                        placeholder="Instruktioner"
                        @bind="createOrder.Instructions">
                    </textarea>

                    <button
                        type="submit"
                        class="w-full mt-0 py-4 bg-[#b5ae9d] hover:bg-[#a8a18f] text-[#1a1a1a] font-black text-base tracking-widest uppercase transition-colors duration-200">

                        Bekräfta order (@(itemTotal * (1 + restaurantServiceFee/100) + restaurantDeliveryCharge):-)
                    </button>
                </EditForm>
            </div>
    </div>
</div>

@code {
    private List<OrderState> cart = new();
    decimal itemPrice = 0;
    int itemQuantity = 0;
    decimal itemTotal = 0;
    decimal restaurantServiceFee = 0;
    decimal restaurantDeliveryCharge = 0;

    private CreateOrderDTO createOrder {get; set;} = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {

        if (firstRender)
        {
            cart = await LocalStorage.GetItemAsync<List<OrderState>>("cart") ?? new();

            foreach (var item in cart)
            {
                itemTotal += item.MenuItem.Price * item.Quantity;
            }

            if (cart.Count > 0)
            {
                restaurantServiceFee = cart[0].Restaurant.ServiceFee;
                restaurantDeliveryCharge = cart[0].Restaurant.DeliveyCharge;
            }

            StateHasChanged();
        }
    }
    public async Task ConfirmOrder()
    {

        var response = await Http.PostAsJsonAsync("/api/order", createOrder);

        if (response.IsSuccessStatusCode)
        {
            var createdOrder = await response.Content.ReadFromJsonAsync<CreateOrderDTO>();

            Nav.NavigateTo("/order-summary");
        }
    }
}