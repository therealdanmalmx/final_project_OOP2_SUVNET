@page "/order/"
@inject HttpClient Http
@inject NavigationManager Nav
@inject OrderStateService OrderState

@using API.Models
@using API.DTO.Order
@using API.DTO.OrderItem
@using Client.DTO
@using Client.Services
@using System.ComponentModel.DataAnnotations

<div class="min-h-screen flex items-center justify-center p-6">
    <div class="w-full max-w-md">

        <h1 class="text-3xl font-black tracking-tight text-[#1a1a1a] mb-6 uppercase">
            Orderbekräftelse
        </h1>

        <div class="mb-6 space-y-2 text-[#1a1a1a]">
            <div class="flex justify-between items-center">
                <span class="font-bold text-base">@OrderState.MenuItem.Name &nbsp; x(@OrderState.Quantity)</span>
                <span class="text-base">@(OrderState.Quantity * OrderState.MenuItem.Price):-</span>
            </div>

            <div class="flex justify-between items-center text-sm mt-3">
                <span>Leveransavgift</span>
                <span>29:-</span>
            </div>
            <div class="flex justify-between items-center text-sm">
                <span>Serviceavgift (@OrderState.Restaurant.ServiceFee%)</span>
                <span>@((OrderState.Quantity * OrderState.MenuItem.Price) * (OrderState.Restaurant.ServiceFee/100))kr</span>
            </div>

            <div class="flex justify-between items-center font-bold text-base pt-2">
                <span>Summa</span>
                <span>@(OrderState.Quantity * OrderState.MenuItem.Price * (1 + OrderState.Restaurant.ServiceFee/100) + 29):-</span>
            </div>
        </div>

        <div class="space-y-0 border border-[#c8c5bb]">
            <EditForm Model="@createOrder" OnValidSubmit="ConfirmOrder">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <input
                    class="w-full px-4 py-4 bg-[#f5f3e8] text-[#1a1a1a] placeholder-[#1a1a1a] border-b border-[#c8c5bb] outline-none text-base focus:bg-[#edebd8]"
                    placeholder="Namn"
                    @bind="createOrder.Name" />

                <input
                    class="w-full px-4 py-4 bg-[#f5f3e8] text-[#1a1a1a] placeholder-[#1a1a1a] border-b border-[#c8c5bb] outline-none text-base focus:bg-[#edebd8]"
                    placeholder="Adress"
                    @bind="createOrder.Address" />

                <input
                    class="w-full px-4 py-4 bg-[#f5f3e8] text-[#1a1a1a] placeholder-[#1a1a1a] border-b border-[#c8c5bb] outline-none text-base focus:bg-[#edebd8]"
                    placeholder="Telefon"
                    @bind="createOrder.Phone" />

                <input
                    class="w-full px-4 py-4 bg-[#f5f3e8] text-[#1a1a1a] placeholder-[#1a1a1a] border-b border-[#c8c5bb] outline-none text-base focus:bg-[#edebd8]"
                    placeholder="Email"
                    type="email"
                    @bind="createOrder.Email" />

                <textarea
                    class="w-full px-4 py-4 bg-[#f5f3e8] text-[#1a1a1a] placeholder-[#1a1a1a] outline-none text-base resize-none h-32 focus:bg-[#edebd8]"
                    placeholder="Instruktioner"
                    @bind="createOrder.Instructions">
                </textarea>

                <button
                    type="submit"
                    class="w-full mt-0 py-4 bg-[#b5ae9d] hover:bg-[#a8a18f] text-[#1a1a1a] font-black text-base tracking-widest uppercase transition-colors duration-200">
                    Bekräfta order (@(OrderState.Quantity * OrderState.MenuItem.Price * (1 + @OrderState.Restaurant.ServiceFee/100) + 29):-)
                </button>
            </EditForm>
        </div>
    </div>
</div>

@code {

    private CreateOrderDTO createOrder {get; set;} = new();
    public async Task ConfirmOrder()
    {
        if (OrderState.Order != null)
        {
            OrderState.Order.Name = createOrder.Name;
            OrderState.Order.Address = createOrder.Address;
            OrderState.Order.Phone = createOrder.Phone;
            OrderState.Order.Email = createOrder.Email;
            OrderState.Order.Instructions = createOrder.Instructions;
        }

        var response = await Http.PostAsJsonAsync("/api/order", createOrder);

        if (response.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/order-summary");
        }

    }
}