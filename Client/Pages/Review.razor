@page "/review/order/{id:guid}"
@using API.DTO.Review
@using Client.DTO

<AuthorizeView>
    <NotAuthorized>
        <p>Du måste vara inloggad för att se denna sida</p>
    </NotAuthorized>
    <Authorized>
        <div class="h-full flex items-center justify-center gap-12 px-4">
            <div class="w-full max-w-lg text-center space-y-6">

                <div class="flex justify-center">
                    <div class="w-20 h-20 rounded-full bg-green-100 flex items-center justify-center">
                        <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                    </div>
                </div>

                <div class="space-y-2">
                    <h1 class="text-4xl font-black tracking-tight text-gray-900 leading-none">
                        Levererad!
                    </h1>
                    <p class="text-gray-500 text-base leading-relaxed">
                        Din beställning har levererats. Hoppas det smakar!
                    </p>
                </div>

                <div class="flex flex-col gap-3 pt-2">
                    <BbButton
                        Color="ButtonColor.Primary"
                        onclick="@(() => Nav.NavigateTo("/"))"
                        Class="w-full py-3.5 rounded-xl font-black text-sm tracking-widest uppercase">
                        Gör en ny beställning
                    </BbButton>
                </div>


            </div>

            @if (alreadyReviewed == false)
            {
                    <div class="w-full max-w-lg space-y-5">

                    <div>
                        <p class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-1">Din åsikt</p>
                        <h1 class="text-4xl font-black tracking-tight text-gray-900 leading-none">Lämna ett omdöme</h1>
                    </div>

                    <BbCard class="rounded-2xl shadow-sm overflow-hidden">
                        <BbCardHeader class="px-8 pt-7 pb-4">
                            <BbCardTitle class="text-sm font-semibold tracking-widest uppercase text-gray-400">
                                Betyg
                            </BbCardTitle>
                        </BbCardHeader>

                        <div class="px-8 pb-7 space-y-3">

                            <div class="flex items-center gap-1">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var step = i;
                                    if (rating >= step)
                                    {
                                        <button @onclick="@(() => SetRating(step))"
                                                class="text-amber-400 hover:scale-110 transition-transform duration-150">
                                            <svg class="w-9 h-9 fill-amber-400" viewBox="0 0 20 20">
                                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                            </svg>
                                        </button>
                                    }
                                    else if (rating >= step - 0.5m)
                                    {
                                        <button @onclick="@(() => SetRating(step - 0.5m))"
                                                class="hover:scale-110 transition-transform duration-150 relative w-9 h-9">
                                            <svg class="w-9 h-9 fill-gray-200 absolute inset-0" viewBox="0 0 20 20">
                                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                            </svg>
                                            <svg class="w-9 h-9 absolute inset-0" viewBox="0 0 20 20" style="clip-path: inset(0 50% 0 0);">
                                                <path class="fill-amber-400" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                            </svg>
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="relative w-9 h-9 inline-block">
                                            <button @onclick="@(() => SetRating(step - 0.5m))"
                                                    class="absolute inset-y-0 left-0 w-1/2 z-10" />
                                            <button @onclick="@(() => SetRating(step))"
                                                    class="absolute inset-y-0 right-0 w-1/2 z-10" />
                                            <svg class="w-9 h-9 fill-gray-200 pointer-events-none" viewBox="0 0 20 20">
                                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                            </svg>
                                        </span>
                                    }
                                }

                                <span class="ml-3 text-2xl font-black text-gray-900 tabular-nums">@rating.ToString("0.0")</span>
                            </div>

                            <p class="text-xs text-gray-400">Klicka på vänster halva av en stjärna för 0.5, höger halva för heltal</p>

                        </div>
                    </BbCard>

                    <BbCard class="rounded-2xl shadow-sm overflow-hidden">
                        <BbCardHeader class="px-8 pt-7 pb-4">
                            <BbCardTitle class="text-sm font-semibold tracking-widest uppercase text-gray-400">
                                Kommentar
                            </BbCardTitle>
                        </BbCardHeader>
                        <div class="px-8 pb-8">
                            <textarea
                                class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-sm text-gray-900 placeholder-gray-400 outline-none focus:border-gray-400 focus:bg-white transition-colors duration-150 resize-none h-36"
                                placeholder="Berätta om din upplevelse..."
                                @bind="comment" />

                            <BbButton
                                Color="ButtonColor.Primary"
                                Class="w-full mt-5 py-3.5 rounded-xl font-black text-sm tracking-widest uppercase"
                                onclick="@SubmitReview">
                                Skicka omdöme
                            </BbButton>
                        </div>
                    </BbCard>
                </div>
            }
        </div>
            @if (alreadyReviewed == true)
            {
                <div class="block w-1/2 mx-auto pt-12">
                    <BbCard class="rounded-2xl shadow-sm overflow-hidden">
                        <div class="px-8 py-10 text-center space-y-2">
                            <div class="flex justify-center mb-3">
                                <div class="w-12 h-12 rounded-full bg-amber-100 flex items-center justify-center">
                                    <svg class="w-6 h-6 text-amber-500" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                                    </svg>
                                </div>
                            </div>
                            @if(Order is not null){<p class="text-base font-bold text-gray-900">Order #@(Order.Number) har ett omdöme</p>}
                            <p class="text-sm text-gray-500">Tack för din feedback!</p>
                        </div>
                    </BbCard>
                </div>
            }

    </Authorized>
</AuthorizeView>


@code {
    [Parameter]
    public Guid Id { get; set; }

    [Parameter]
    public GetOrderDTO? Order { get; set; }

    private decimal rating = 0m;
    private string comment = "";
    private void SetRating(decimal value) => rating = value;
    private bool? alreadyReviewed = null;

    protected override async Task OnInitializedAsync()
    {
        var response = await Http.GetAsync($"api/review/order/{Id}");
        alreadyReviewed = response.IsSuccessStatusCode;
        Order = await Http.GetFromJsonAsync<GetOrderDTO>($"api/order/{Id}");

    }

    private async Task SubmitReview()
    {
        if (rating == 0) return;
        if (alreadyReviewed == true) return;

        var review = new AddNewReviewDTO
        {
            Score = rating,
            Comment = comment,
            OrderId = Id
        };

        var response = await Http.PostAsJsonAsync("api/review", review);

        if (response.IsSuccessStatusCode)
        {
            alreadyReviewed = true;
            @* Nav.NavigateTo("/"); *@
        }
    }
}