@page "/restaurant/{Id:guid}"
@inject NavigationManager Nav;
@using Blazored.LocalStorage
@using Client.Components
@using Client.DTO
@using Client.Models
@using System.Runtime.InteropServices

@inject HttpClient Http
@inject ILocalStorageService LocalStorage



@if (restaurant is null)
{
    return;
}

<PageTitle>@restaurant?.Name</PageTitle>

<RestaurantInfo restaurant="restaurant" isopen="isopen"/>

<MenuItemCard restaurant="restaurant" isopen="isopen" />


@code {
    [Parameter]
    public Guid Id { get; set; }
    private GetRestaurantsDTO? restaurant;
    private bool isopen {get; set; } = true;

    protected override async Task OnParametersSetAsync()
    {
        restaurant = await Http.GetFromJsonAsync<GetRestaurantsDTO>($"api/restaurant/{Id}");

        if(TimeOnly.FromDateTime(DateTime.Now) < restaurant.Opens || TimeOnly.FromDateTime(DateTime.Now) > restaurant.Closes)
        {
            isopen = false;
        }

    }

}