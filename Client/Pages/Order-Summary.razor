@page "/order-summary"
@using Client.DTO
@using API.Models
@using Client.Services
@inject OrderStateService OrderState

<div class="min-h-screen bg-[#e8e6df] p-6">
    <div class="w-full max-w-md mx-auto">

        <!-- Order Header -->
        <div class="mb-6">
            @if(OrderState is not null)
            {
                <h1 class="text-3xl font-black tracking-tight text-[#1a1a1a] uppercase">
                    Order: #@OrderState?.Order?.Number
                </h1>
            }
            <p class="text-base text-[#1a1a1a] mt-1">
                @if(OrderState is not null)
                {
                    <div class="font-bold">@OrderState?.MenuItem?.Name x @OrderState?.Quantity</div>
                    <span> från </span>
                    <span class="font-bold">@OrderState?.Restaurant?.Name</span>
                }
            </p>
        </div>

        <!-- Delivery Info -->
        <div class="mb-10 space-y-1 text-base text-[#1a1a1a]">
            @if(OrderState is not null)
            {
                <p>
                    Din order levereras till dig av:
                    <span class="font-bold">@OrderState?.Order?.CourierId.ToString()</span>
                </p>

            }
            @if(OrderState is not null)
            {
                <p>
                    Status: <span class="font-bold">@ConvertStatusCode(OrderState.Order.Status).</span>
                    Leveranstid: <span class="font-bold">@DeliveryMinutes minuter</span>
                </p>
            }
        </div>

        <!-- Delivery Address -->
        <div class="mb-16 text-base text-[#1a1a1a]">
            @if(OrderState is not null)
            {
                <div class="font-bold mb-3">Levereras till:</div>
                    <div>@OrderState?.Order?.Name</div>
                    <div>@OrderState?.Order?.Address</div>
            }
        </div>

        <!-- Cancel Button -->
        <button
            class="w-full py-4 bg-[#ccc9be] hover:bg-[#b8b5aa] text-[#888580] font-black text-base tracking-widest uppercase transition-colors duration-200 cursor-pointer"
            @onclick="CancelOrder">
            Avbryt!
        </button>

    </div>
</div>

@code {
    // These would come from your order service / injected state
    private string CourierName { get; set; } = "Krister T";
    private string CourierRating { get; set; } = "4.8";
    private int DeliveryMinutes { get; set; } = 8;

    public GetOrderDTO? Order {get; set; }

    protected override async Task OnParametersSetAsync()
    {
        Order = await Http.GetFromJsonAsync<GetOrderDTO>($"/api/order/{OrderState.Order?.Id}");
    }
    private void CancelOrder()
    {
        // Handle cancellation
    }

    public string ConvertStatusCode(Status code)
    {
        return code switch
        {
            Status.received => "received",
            Status.confirmed => "confirmed",
            Status.courier_accepted => "courier_accepted",
            Status.preparing => "preparing",
            Status.ready_for_pickup => "ready_for_pickup",
            Status.in_transit => "in_transit",
            Status.delivered => "delivered",
        };
    }
}