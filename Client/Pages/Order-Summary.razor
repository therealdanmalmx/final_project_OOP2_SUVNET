@page "/order-summary/{Id:guid}"
@using API.DTO
@using Client.DTO
@using API.Models
@using Blazored.LocalStorage
@using Client.Models
@inject HttpClient Http
@inject ILocalStorageService LocalStorage

<div class="min-h-screen bg-[#e8e6df] p-6">
    <div class="w-full max-w-md mx-auto">

        @if (Order is null)
        {
            <div id="app"> </div>
        }
        else
        {
            <h1 class="text-3xl font-black tracking-tight text-[#1a1a1a] uppercase">
                Order: #@Order.Number
            </h1>

            <div class="mb-6">
                <p class="text-base text-[#1a1a1a] mt-1">
                    @foreach (var item in Order.OrderItems)
                    {
                        <div class="font-bold">@item.Name x @item.Quantity</div>
                    }
                    <span> från </span>
                    <span class="font-bold">@restaurantName</span>
                </p>
            </div>

            <div class="mb-10 space-y-1 text-base text-[#1a1a1a]">
                <p>
                    Din order levereras till dig av:
                    <span class="font-bold">@courierName</span>
                </p>
                <p>
                    Status: <span class="font-bold">@ConvertStatusCode(Order.Status)</span>
                    Leveranstid: <span class="font-bold">@DeliveryMinutes minuter</span>
                </p>
            </div>

            <div class="mb-16 text-base text-[#1a1a1a]">
                <div class="font-bold mb-3">Levereras till:</div>
                <div>@Order.Name</div>
                <div>@Order.Address</div>
            </div>

            <button
                class="w-full py-4 bg-[#ccc9be] hover:bg-[#b8b5aa] text-[#888580] font-black text-base tracking-widest uppercase transition-colors duration-200 cursor-pointer"
                @onclick="CancelOrder">
                Avbryt!
            </button>
        }
    </div>
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private int DeliveryMinutes { get; set; } = 8;
    private string restaurantName { get; set; } = "";
    private string courierName { get; set; } = "";
    public GetOrderDTO? Order { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        Order = await Http.GetFromJsonAsync<GetOrderDTO>($"/api/order/{Id}");

        var cart = await LocalStorage.GetItemAsync<List<OrderState>>("cart");
        restaurantName = cart?.FirstOrDefault()?.Restaurant?.Name ?? "";

        if (Order?.CourierId is not null)
        {
            courierName = await GetCourierName(Order.CourierId);
        }

        StateHasChanged();
    }

    private async Task<string> GetCourierName(Guid? courierId)
    {
        var response = await Http.GetAsync($"/api/courier/{courierId}");

        if (!response.IsSuccessStatusCode)
        {
            return "Ej tilldelad";
        }

        var courier = await response.Content.ReadFromJsonAsync<GetCourierDTO>();
        return courier?.Name ?? "Ej tilldelad";
    }

    private void CancelOrder() { }

    public string ConvertStatusCode(Status code)
    {
        return code switch
        {
            Status.received => "Mottagen",
            Status.confirmed => "Bekräftad",
            Status.courier_accepted => "Bud accepterat",
            Status.preparing => "Förberedes",
            Status.ready_for_pickup => "Redo för upphämtning",
            Status.in_transit => "På väg",
            Status.delivered => "Levererad",
            _ => "Okänd"
        };
    }
}